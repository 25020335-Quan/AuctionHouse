<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" stylesheets="@../css/addItem.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="auction.controller.AddItemController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="625.0" prefWidth="1000.0" spacing="10.0" styleClass="form-card">
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>
         <children>
            <Label styleClass="title" text="POST NEW ITEM" />
            <Label prefHeight="40.0" prefWidth="173.0" styleClass="subtitle" text="Complete the details below" />
            <HBox prefHeight="474.0" prefWidth="920.0" spacing="40.0">
               <children>
                  <VBox prefHeight="484.0" prefWidth="920.0" spacing="2.0" styleClass="input-field" HBox.hgrow="ALWAYS">
                     <children>
                        <Label prefHeight="19.0" prefWidth="158.0" text="Item Type" />
                        <ComboBox fx:id="typeField" prefHeight="30.0" prefWidth="422.0" />
                        <Label prefHeight="17.0" prefWidth="102.0" text="Item Name" />
                        <TextField fx:id="nameField" maxWidth="-Infinity" prefHeight="26.0" prefWidth="421.0">
                           <VBox.margin>
                              <Insets />
                           </VBox.margin>
                        </TextField>
                        <Label prefHeight="13.0" prefWidth="144.0" text="Starting Price" />
                        <TextField fx:id="priceField" maxWidth="-Infinity" prefHeight="29.0" prefWidth="420.0">
                           <VBox.margin>
                              <Insets />
                           </VBox.margin>
                        </TextField>
                        <Label text="Start Time" />
                        <HBox prefHeight="28.0" prefWidth="397.0" spacing="20.0">
                           <children>
                              <DatePicker fx:id="startDatePicker" prefHeight="30.0" prefWidth="199.0" />
                              <ComboBox fx:id="startHourCombo" prefHeight="30.0" prefWidth="75.0" />
                              <ComboBox fx:id="startMinuteCombo" prefHeight="30.0" prefWidth="84.0" />
                           </children>
                        </HBox>
                        <Label prefHeight="20.0" prefWidth="69.0" text="End Time" />
                        <HBox prefHeight="36.0" prefWidth="397.0" spacing="20.0">
                           <children>
                              <DatePicker fx:id="endDatePicker" prefHeight="30.0" prefWidth="199.0" />
                              <ComboBox fx:id="endHourCombo" prefHeight="30.0" prefWidth="76.0" />
                              <ComboBox fx:id="endMinuteCombo" prefHeight="30.0" prefWidth="81.0" />
                           </children>
                        </HBox>
                        <Label prefHeight="28.0" prefWidth="141.0" text="Item Description" />
                        <TextArea fx:id="descriptionField" maxWidth="-Infinity" prefHeight="129.0" prefRowCount="5" prefWidth="397.0">
                           <VBox.margin>
                              <Insets />
                           </VBox.margin>
                        </TextArea>
                     </children>
                  </VBox>
                  <VBox maxWidth="-Infinity" prefHeight="464.0" prefWidth="954.0" spacing="10.0">
                     <children>
                        <VBox fx:id="dragDropBox" prefHeight="195.0" prefWidth="458.0" styleClass="drag-drop-box">
                           <children>
                              <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                                 <VBox.margin>
                                    <Insets left="150.0" />
                                 </VBox.margin>
                              </ImageView>
                              <Label alignment="CENTER" prefHeight="37.0" prefWidth="231.0" text="Drag and drop your image here">
                                 <VBox.margin>
                                    <Insets left="130.0" top="20.0" />
                                 </VBox.margin>
                              </Label>
                           </children>
                        </VBox>
                        <FlowPane fx:id="imagePreviewPane" prefHeight="169.0" prefWidth="458.0" />
                        <Button fx:id="selectMoreFiles" mnemonicParsing="false" prefHeight="26.0" prefWidth="251.0" styleClass="btn-secondary" text="Select more files">
                           <VBox.margin>
                              <Insets left="130.0" />
                           </VBox.margin>
                        </Button>
                        <Button fx:id="saveItem" mnemonicParsing="false" onAction="#handleSave" prefHeight="29.0" prefWidth="254.0" styleClass="btn-primary" text="POST ITEM">
                           <VBox.margin>
                              <Insets left="130.0" />
                           </VBox.margin>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
