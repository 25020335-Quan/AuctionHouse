<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="auction.controller.AddItemController">
   <children>
      <Label alignment="CENTER" layoutX="193.0" layoutY="33.0" prefHeight="40.0" prefWidth="194.0" text="Post New Item" textFill="#e70c0c">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label alignment="CENTER" layoutX="162.0" layoutY="184.0" prefHeight="31.0" prefWidth="62.0" text="Name">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="nameField" layoutX="271.0" layoutY="187.0" prefHeight="26.0" prefWidth="170.0" />
      <Label alignment="CENTER" layoutX="165.0" layoutY="73.0" prefHeight="20.0" prefWidth="270.0" text="Please enter your item's information">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
      <Label alignment="CENTER" layoutX="167.0" layoutY="249.0" prefHeight="26.0" prefWidth="50.0" text="Price">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="priceField" layoutX="271.0" layoutY="249.0" prefHeight="26.0" prefWidth="170.0" />
      <Label alignment="CENTER" layoutX="169.0" layoutY="128.0" prefHeight="31.0" prefWidth="50.0" text="Type">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="typeField" layoutX="271.0" layoutY="131.0" prefHeight="26.0" prefWidth="170.0" />
      <Button fx:id="saveItem" layoutX="264.0" layoutY="321.0" mnemonicParsing="false" onAction="#handleSave" prefHeight="26.0" prefWidth="62.0" text="Save" />
   </children>
</AnchorPane>
